# Cursor Cloud Agents API (aanbevolen — geen Automation-dashboard nodig)
CURSOR_API_KEY=cursor_...
CURSOR_REPO_URL=https://github.com/Casper-Schepkens/personal-website
CURSOR_BASE_REF=master
CURSOR_MODE=agent

# Of: Cursor Automation webhook (zet CURSOR_MODE=automation)
# CURSOR_AUTOMATION_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/...
# CURSOR_AUTOMATION_AUTH_TOKEN=crsr_...

# HTTP bridge (alleen voor start:http)
# BRIDGE_SECRET=een-lang-geheim
# PORT=8787
