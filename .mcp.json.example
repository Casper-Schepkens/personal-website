{
  "mcpServers": {
    "claude-cursor-bridge": {
      "command": "node",
      "args": ["integrations/claude-cursor-bridge/src/mcp-server.js"],
      "env": {
        "CURSOR_API_KEY": "${CURSOR_API_KEY}",
        "CURSOR_REPO_URL": "https://github.com/Casper-Schepkens/personal-website",
        "CURSOR_BASE_REF": "master",
        "CURSOR_MODE": "agent"
      }
    }
  }
}
